# EcoIT App — Environment Variables Template
# Copy to .env và điền giá trị thật

APP_NAME=ecoit-app
APP_ENV=development
APP_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=info

# Database
POSTGRES_HOST=ecoit-postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecoit_db
POSTGRES_USER=ecoit_user
POSTGRES_PASSWORD=changeme_local_password
DATABASE_URL=postgresql+asyncpg://ecoit_user:changeme_local_password@ecoit-postgres:5432/ecoit_db

# Redis
REDIS_URL=redis://ecoit-redis:6379/0

# Security (generate random: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=changeme-jwt-secret-must-be-32-chars-minimum
ADMIN_API_KEY=changeme-admin-key

# AI APIs (uncomment khi cần)
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
