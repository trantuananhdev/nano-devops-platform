# LLM Node — llama-server + Caddy TLS + Node Exporter + Promtail
# Managed by Ansible role: llm_node
# T-31: Production-grade LLM node with TLS, metrics, log shipping

services:
  # ---------------------------------------------------------------------------
  # llama-server: Gemma 4 GGUF inference (listens ONLY on 127.0.0.1)
  # ---------------------------------------------------------------------------
  llama-server:
    image: {{ llm_docker_image }}
    container_name: llama-server
    restart: unless-stopped
    # Bind to loopback only — Caddy is the only external entry point
    ports:
      - "127.0.0.1:{{ llm_internal_port }}:{{ llm_internal_port }}"
    volumes:
      - ./models:/models:ro
    command: >
      --model /models/{{ llm_model_file }}
      --host 0.0.0.0
      --port {{ llm_internal_port }}
      -c {{ llm_context_size }}
      -t {{ llm_threads }}
      --chat-template gemma
      --no-mmap
    deploy:
      resources:
        limits:
          memory: {{ llm_memory_limit }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:{{ llm_internal_port }}/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 300s
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "3"

{% if llm_tls_enabled %}
  # ---------------------------------------------------------------------------
  # Caddy: Reverse proxy with TLS self-signed + rate limiting
  # Proxies HTTP :{{ llm_port }} and HTTPS :{{ llm_tls_port }} → llama-server :{{ llm_internal_port }}
  # ---------------------------------------------------------------------------
  llm-caddy:
    image: {{ caddy_docker_image }}
    container_name: llm-caddy
    restart: unless-stopped
    network_mode: host    # Host network so Caddy can reach llama-server on 127.0.0.1
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - ./caddy-data:/data        # TLS cert persistence
    depends_on:
      llama-server:
        # T-63: service_started (not service_healthy) — llama-server takes 3-8min
        # to load Gemma 4 3.35GB. service_healthy would block compose up and fail
        # immediately. Caddy will return 502 until model is ready — acceptable.
        condition: service_started
    deploy:
      resources:
        limits:
          memory: 128m
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "3"
{% endif %}

{% if llm_metrics_enabled %}
  # ---------------------------------------------------------------------------
  # node-exporter: System metrics for Prometheus scrape (Alpine VM)
  # ---------------------------------------------------------------------------
  node-exporter:
    image: {{ node_exporter_image }}
    container_name: node-exporter
    restart: unless-stopped
    ports:
      - "{{ node_exporter_port }}:9100"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.rootfs=/rootfs'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
    deploy:
      resources:
        limits:
          memory: 64m
{% endif %}

{% if llm_log_shipping_enabled %}
  # ---------------------------------------------------------------------------
  # Promtail: Ship llama-server + Caddy logs → Alpine VM Loki
  # ---------------------------------------------------------------------------
  promtail:
    image: {{ promtail_image }}
    container_name: llm-promtail
    restart: unless-stopped
    volumes:
      - ./promtail/config.yml:/etc/promtail/config.yml:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    command: -config.file=/etc/promtail/config.yml
    deploy:
      resources:
        limits:
          memory: 64m
    depends_on:
      - llama-server
{% endif %}
