# =============================================================================
# docker-compose.ecoit.yml — EcoIT App Stack on Ubuntu Server
# Generated by Ansible role: ecoit_app
# Managed by: deploy-ecoit.yml
# =============================================================================

version: '3.9'

x-logging: &default-logging
  driver: json-file
  options:
    max-size: "10m"
    max-file: "3"

services:

  # ---------------------------------------------------------------------------
  # Backend — FastAPI (Python) or Node.js — image built by CI
  # ---------------------------------------------------------------------------
  ecoit-backend:
    image: {{ ecoit_registry }}/{{ ecoit_repo_owner }}/{{ ecoit_app_name }}-backend:{{ ecoit_image_tag }}
    container_name: ecoit-backend
    restart: unless-stopped
    env_file: .env
    environment:
      - APP_PORT={{ ecoit_deploy_port }}
      - DATABASE_URL=postgresql+asyncpg://{{ ecoit_postgres_user }}:{{ ecoit_postgres_password }}@ecoit-postgres:5432/{{ ecoit_postgres_db }}
      - REDIS_URL={{ ecoit_redis_url }}
    ports:
      - "{{ ecoit_deploy_port }}:{{ ecoit_deploy_port }}"
    depends_on:
      ecoit-postgres:
        condition: service_healthy
      ecoit-redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ ecoit_deploy_port }}/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512m
          cpus: "1.0"
    logging: *default-logging
    networks:
      - ecoit-network

  # ---------------------------------------------------------------------------
  # Frontend — Next.js / React (static or SSR)
  # ---------------------------------------------------------------------------
  ecoit-frontend:
    image: {{ ecoit_registry }}/{{ ecoit_repo_owner }}/{{ ecoit_app_name }}-frontend:{{ ecoit_image_tag }}
    container_name: ecoit-frontend
    restart: unless-stopped
    env_file: .env
    environment:
      - NEXT_PUBLIC_API_URL=http://{{ ansible_host }}:{{ ecoit_deploy_port }}
      - PORT={{ ecoit_frontend_port }}
    ports:
      - "{{ ecoit_frontend_port }}:{{ ecoit_frontend_port }}"
    depends_on:
      - ecoit-backend
    deploy:
      resources:
        limits:
          memory: 256m
          cpus: "0.5"
    logging: *default-logging
    networks:
      - ecoit-network

  # ---------------------------------------------------------------------------
  # PostgreSQL — persistent database
  # ---------------------------------------------------------------------------
  ecoit-postgres:
    image: postgres:16-alpine
    container_name: ecoit-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ ecoit_postgres_db }}
      POSTGRES_USER: {{ ecoit_postgres_user }}
      POSTGRES_PASSWORD: {{ ecoit_postgres_password }}
    volumes:
      - {{ ecoit_app_dir }}/data/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ ecoit_postgres_user }} -d {{ ecoit_postgres_db }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 256m
    logging: *default-logging
    networks:
      - ecoit-network

  # ---------------------------------------------------------------------------
  # Redis — cache & queue
  # ---------------------------------------------------------------------------
  ecoit-redis:
    image: redis:7.2-alpine
    container_name: ecoit-redis
    restart: unless-stopped
    command: redis-server --maxmemory 128mb --maxmemory-policy allkeys-lru
    volumes:
      - {{ ecoit_app_dir }}/data/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 160m
    logging: *default-logging
    networks:
      - ecoit-network

networks:
  ecoit-network:
    driver: bridge
    name: ecoit-network
