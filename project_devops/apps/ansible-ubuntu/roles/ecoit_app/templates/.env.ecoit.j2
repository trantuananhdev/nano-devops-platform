# =============================================================================
# EcoIT App — Environment Variables
# Generated by Ansible role: ecoit_app
# DO NOT edit manually — regenerated on each deploy
# =============================================================================

APP_NAME={{ ecoit_app_name }}
APP_ENV={{ ecoit_env }}
APP_PORT={{ ecoit_deploy_port }}
FRONTEND_PORT={{ ecoit_frontend_port }}

# Database
POSTGRES_HOST=ecoit-postgres
POSTGRES_PORT=5432
POSTGRES_DB={{ ecoit_postgres_db }}
POSTGRES_USER={{ ecoit_postgres_user }}
POSTGRES_PASSWORD={{ ecoit_postgres_password }}
DATABASE_URL=postgresql+asyncpg://{{ ecoit_postgres_user }}:{{ ecoit_postgres_password }}@ecoit-postgres:5432/{{ ecoit_postgres_db }}

# Redis
REDIS_URL={{ ecoit_redis_url }}

# Image registry
REGISTRY={{ ecoit_registry }}
REPO_OWNER={{ ecoit_repo_owner }}
IMAGE_TAG={{ ecoit_image_tag }}

# Security
JWT_SECRET={{ lookup('env', 'JWT_SECRET') | default('changeme-jwt-secret-32chars-min', true) }}
ADMIN_API_KEY={{ lookup('env', 'ADMIN_API_KEY') | default('changeme-admin-key', true) }}

# AI (optional — fill when EcoIT task requires)
GEMINI_API_KEY={{ lookup('env', 'GEMINI_API_KEY_1') | default('', true) }}
OPENAI_API_KEY={{ lookup('env', 'OPENAI_API_KEY') | default('', true) }}

# Observability
LOG_LEVEL=info
METRICS_PORT=9100
