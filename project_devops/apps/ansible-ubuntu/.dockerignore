# Ansible artefacts
*.retry
.ansible/
__pycache__/

# SSH keys:
#   prod_deployer     → EXCLUDED (private key — never bake into image)
#                       provided at runtime via Docker secret /run/secrets/prod_deployer
#   prod_deployer.pub → INCLUDED (public key — safe, needed for reference)
.ssh/prod_deployer

# Legacy key names (kept for safety in case old files exist)
.ssh/prod_key
.ssh/prod_key.pub

# Local override inventory
inventory/hosts.local.ini
