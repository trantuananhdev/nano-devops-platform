# Digital FTE Platform - Production Environment Template
# Copy this to .env and fill in the values for your deployment.

# --- Core Platform ---
PORT=3000
NODE_ENV=production
# Managed Database (Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname?ssl=true

# --- Security ---
# Random string (min 32 chars)
JWT_SECRET=your_long_random_jwt_secret_here
JWT_EXPIRES_IN=1h
# Secure key for admin operations
ADMIN_API_KEY=your_secure_admin_api_key_here
# Must match GitHub Webhook setting
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
ALLOW_UNSIGNED_WEBHOOKS=false

# --- LLM Providers (Configure at least one) ---
LLM_PROVIDER=openai # openai, claude, or gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-pro
GEMINI_API_VERSION=v1beta

# --- Performance & Limits ---
AGENT_MAX_ATTEMPTS=3
TEST_TIMEOUT_MS=600000
GITHUB_API_TIMEOUT_MS=30000
MAX_FILE_CHARS=4000
LOG_TRIM_CHARS=20000
GIT_CLONE_DEPTH=50
