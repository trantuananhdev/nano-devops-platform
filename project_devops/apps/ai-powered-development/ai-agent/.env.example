PORT=3000

# Postgres
DATABASE_URL=postgres://dfte:dfte@postgres:5432/dfte

# Auth (access token only)
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
ADMIN_API_KEY=change-me-admin

# LLM (OpenAI only)
OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1500
OPENAI_TIMEOUT_MS=60000

# GitHub integration
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret
ALLOW_UNSIGNED_WEBHOOKS=false

# Agent behavior
AGENT_MAX_ATTEMPTS=3
MAX_FILE_CHARS=4000
TEST_TIMEOUT_MS=600000
GITHUB_API_TIMEOUT_MS=30000
LOG_TRIM_CHARS=20000

