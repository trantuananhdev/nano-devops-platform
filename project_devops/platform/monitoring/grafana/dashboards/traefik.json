{
  "dashboard": {
    "title": "Traefik",
    "tags": ["traefik", "edge", "reverse-proxy"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "type": "stat",
        "title": "Request Rate",
        "targets": [
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total[5m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "thresholds"},
            "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}]}
          }
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "type": "stat",
        "title": "Error Rate",
        "targets": [
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total{code=~\"5..\"}[5m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "thresholds"},
            "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 10, "color": "red"}]}
          }
        }
      },
      {
        "id": 3,
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "type": "stat",
        "title": "P95 Latency",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(traefik_entrypoint_request_duration_seconds_bucket[5m])) by (le))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "color": {"mode": "thresholds"},
            "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.1, "color": "yellow"}, {"value": 0.5, "color": "red"}]}
          }
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "type": "stat",
        "title": "Active Connections",
        "targets": [
          {
            "expr": "sum(traefik_entrypoint_open_connections)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}]}
          }
        }
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "type": "timeseries",
        "title": "Request Rate by Entrypoint",
        "targets": [
          {
            "expr": "rate(traefik_entrypoint_requests_total[5m])",
            "refId": "A",
            "legendFormat": "{{entrypoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "type": "timeseries",
        "title": "Request Duration (p50, p95, p99)",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(traefik_entrypoint_request_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "p50 {{entrypoint}}"
          },
          {
            "expr": "histogram_quantile(0.95, rate(traefik_entrypoint_request_duration_seconds_bucket[5m]))",
            "refId": "B",
            "legendFormat": "p95 {{entrypoint}}"
          },
          {
            "expr": "histogram_quantile(0.99, rate(traefik_entrypoint_request_duration_seconds_bucket[5m]))",
            "refId": "C",
            "legendFormat": "p99 {{entrypoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "type": "timeseries",
        "title": "HTTP Status Codes",
        "targets": [
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total{code=~\"2..\"}[5m])) by (code)",
            "refId": "A",
            "legendFormat": "{{code}}"
          },
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total{code=~\"4..\"}[5m])) by (code)",
            "refId": "B",
            "legendFormat": "{{code}}"
          },
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total{code=~\"5..\"}[5m])) by (code)",
            "refId": "C",
            "legendFormat": "{{code}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "type": "timeseries",
        "title": "Error Rate",
        "targets": [
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total{code=~\"5..\"}[5m]))",
            "refId": "A",
            "legendFormat": "5xx Errors"
          },
          {
            "expr": "sum(rate(traefik_entrypoint_requests_total{code=~\"4..\"}[5m]))",
            "refId": "B",
            "legendFormat": "4xx Errors"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "palette-classic"}
          }
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {}
  }
}