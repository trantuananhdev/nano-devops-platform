# Nano DevOps Platform + HDTV AI — copy to .env (DO NOT COMMIT .env)

# --- AI Agent Identity ---
GIT_USER_NAME="Ghost Engineer"
GIT_USER_EMAIL="ghost@nano.platform"

# --- AI Agent Security ---
JWT_SECRET="ghost-engineer-secret-key-12345"
ADMIN_API_KEY="devadmin-api-key"

# --- Vagrant VM ---
# REQUIRED: static IP for Alpine VM (validate_env.sh)
VM_IP=192.168.157.10
VM_MEM=4096

# --- HDTV LLM (Ubuntu llama-server) ---
# REQUIRED: ACER_HOST — Ubuntu LLM node IPv4 (validate_env.sh)
# OPTIONAL: LLM_BASE_URL — để trống → tự build http://<ACER_HOST>:8080/v1
# Nếu muốn override hoàn toàn thì uncomment:
# LLM_BASE_URL=http://192.168.100.6:8080/v1
LLM_MODEL=gemma-4-E2B-it
LLM_TIMEOUT=120.0

# --- Gemini 2.5 Flash (tool mocks + specialist agents) ---
# OPTIONAL: GEMINI_API_KEY — warn if empty; tool mocks degraded without it
LLM_PROVIDER="gemini"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=4096
GEMINI_HTTP_RETRIES=3
GEMINI_HTTP_RETRY_BACKOFF_S=2.0

# --- Extra Gemini keys for round-robin rotation ---
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
OPENAI_API_KEY=

# --- Shopee: demo fixture (không cào live) ---
SHOPEE_DEMO_FALLBACK=true
SHOPEE_AUTO_FALLBACK_ON_BLOCK=true
SHOPEE_AUTO_COOKIE_BOOTSTRAP=false
SHOPEE_USE_PLAYWRIGHT=false
SHOPEE_FETCH_TIMEOUT_SEC=25
SHOPEE_HTTP_RETRIES=1
SHOPEE_HTTP_PROXY=
SHOPEE_HTTP_COOKIE=
SHOPEE_LLM_EXPLAIN=true
SHOPEE_LLM_FALLBACK=true

# --- Bootstrap Repo Configuration ---
BOOTSTRAP_REPO_FULL_NAME="trantuananhdev/nano-devops-platform"
BOOTSTRAP_GITHUB_TOKEN=

# --- Telegram Bot Configuration ---
# OPTIONAL: TELEGRAM_BOT_TOKEN — warn if empty; Alertmanager notifications disabled
# Bot 1: Dùng để gửi alert lead khẩn
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bot 2: Dùng để tự động reply khách và tạo lead (mới bạn vừa tạo)
TELEGRAM_CRM_BOT_TOKEN=

# --- Global Tokens ---
GITHUB_TOKEN=
GITLAB_TOKEN=

# --- SSH Key Configuration ---
BOOTSTRAP_SSH_KEY=

# --- Acer Physical Host — AI Data Layer + Ansible Deploy Target ---
# ⚠️  ĐỔI IP NÀY khi chuyển máy server. Mọi nơi khác tự cập nhật theo.
ACER_HOST=192.168.100.6
ACER_SSH_PORT=22
# Ansible kết nối root@ACER_HOST qua prod_deployer (ed25519).
# Tạo key: ssh-keygen -t ed25519 -f .ssh/prod_deployer -N ""
# Inject:  ssh-copy-id -i .ssh/prod_deployer.pub root@<ACER_HOST>

# --- EcoIT Trial — Application Config ---
ECOIT_APP_NAME=ecoit-app
ECOIT_DEPLOY_PORT=8000
ECOIT_FRONTEND_PORT=3000
ECOIT_ENV=production
ECOIT_POSTGRES_PASSWORD=changeme_ecoit_db_password

# --- Auto reset Ubuntu LLM server ---
RESET_UBUNTU_LLM=false

# --- Hugging Face Token (optional, for private/gated models) ---
HF_TOKEN=

# --- LLM Router role → backend mapping (optional overrides) ---
# Default: planner/executor/reflector/summary → local (Ubuntu Gemma 4)
#          legal/financial/ocr/critic/tool_mock → gemini

# ===========================================================================
# HDTV Database
# Passwords → project_devops/platform/secrets/*.txt  (Docker secrets, gitignored)
# Chạy lần đầu: bash project_devops/platform/infra/scripts/system/setup_secrets.sh \
#               project_devops/platform/composition
# ===========================================================================
HDTV_POSTGRES_DB=hdtv_db
HDTV_POSTGRES_USER=hdtv_user
# HDTV_POSTGRES_PASSWORD  → secret file: platform/secrets/hdtv_postgres_password.txt
# (docker-compose inject vào /run/secrets/hdtv_postgres_password)

# --- MinIO ---
MINIO_ROOT_USER=hdtv_minio
# MINIO_ROOT_PASSWORD  → secret file: platform/secrets/minio_root_password.txt

# --- Meilisearch ---
# MEILI_MASTER_KEY  → secret file: platform/secrets/meili_master_key.txt

# --- HDTV Auto Seed ---
HDTV_AUTO_SEED=true

# ===========================================================================
# Platform Database
# POSTGRES_PASSWORD → secret file: platform/secrets/postgres_password.txt
# ===========================================================================

# --- Grafana Admin ---
# GF_SECURITY_ADMIN_PASSWORD → secret file: platform/secrets/grafana_password.txt
